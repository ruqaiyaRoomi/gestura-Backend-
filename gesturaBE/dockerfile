FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
build-essential \
g++ \
libstdc++6 \
nodejs \
npm \
&& rm -rf /var/lib/apt/lists/*


COPY package.json  package-lock.json ./
RUN npm ci

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
CMD ["node", "server.js"]